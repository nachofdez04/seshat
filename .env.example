# PostgreSQL (used by docker-compose and the app)
POSTGRES_USER=seshat
POSTGRES_PASSWORD=seshat
POSTGRES_DB=seshat
POSTGRES_PORT=5432

# LocalStack — fake AWS services for local dev and integration tests
LOCALSTACK_PORT=4566
AWS_DEFAULT_REGION=eu-west-1
# LocalStack accepts any non-empty credentials; these are not real AWS keys
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# AWS resource names (resolved at runtime; LocalStack uses these too)
S3_BUCKET=seshat-mvp
POSTGRES_SECRET_NAME=seshat/postgres_url

# Required for AI pipeline integration tests; leave blank to skip those tests
OPENAI_API_KEY=
